# VERCEL PRODUCTION ENVIRONMENT VARIABLES
# ============================================
#
# INSTRUÇÕES PARA UPLOAD NO VERCEL:
# 1. Clique em "Import .env" na seção Environment Variables
# 2. Cole TODO o conteúdo deste arquivo
# 3. Verifique se todas as variáveis foram importadas
# 4. Clique em Deploy
#
# ⚠️ IMPORTANTE: Substitua os valores de STRIPE com suas chaves REAIS
# ============================================

# 🔑 STRIPE - Payment Processing
STRIPE_SECRET_KEY=sk_live_sua_chave_secreta_live_aqui
STRIPE_PUBLISHABLE_KEY=pk_live_sua_chave_publica_live_aqui
STRIPE_WEBHOOK_SECRET=whsec_seu_webhook_secret_aqui

# 🗄️ SUPABASE (Frontend + funções)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua_chave_anon_publica_aqui

# Opcional: manter sincronizado com Edge Functions/cronjobs
# SUPABASE_SERVICE_KEY=sua_service_role_key_aqui

# 🌐 SERVER CONFIGURATION
NODE_ENV=production
PORT=3001

# 🔒 CORS - Allowed Origins
CORS_ORIGINS=https://garciabuilder.fitness,https://www.garciabuilder.fitness,https://garciabuilder-fitness.vercel.app

# 🔗 URLs - Frontend and Redirects
FRONTEND_URL=https://garciabuilder.fitness
PUBLIC_SITE_URL=https://garciabuilder.fitness
SUCCESS_URL=https://garciabuilder.fitness/success.html
CANCEL_URL=https://garciabuilder.fitness/pricing.html

# Google Tag Manager / GA4
# GA4 is managed through GTM; do not load GA4 directly in frontend scripts.
NEXT_PUBLIC_GTM_ID=GTM-TG5TFZ2C
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-CMMHJP9LEY

# 💰 STRIPE PRICE IDs - Substitua pelos seus Price IDs reais do dashboard Stripe
PRICE_STARTER=price_1234567890_starter
PRICE_CONSISTENCY=price_1234567890_consistency
PRICE_PERFORMANCE=price_1234567890_performance
PRICE_PREMIUM=price_1234567890_premium
PRICE_ELITE=price_1234567890_elite

# 📧 EMAIL CONFIGURATION (Opcional - para notificações)
# EMAIL_SERVICE=gmail
# EMAIL_USER=seu-email@gmail.com
# EMAIL_PASS=sua-senha-app

# 🔁 ZAPIER AUTOMATIONS (server-side only; do not expose in frontend)
ZAPIER_LEAD_WEBHOOK_URL=
ZAPIER_MAIN_COACHING_WEBHOOK_URL=
ZAPIER_HOT_LEAD_WEBHOOK_URL=
ZAPIER_EBOOK_WEBHOOK_URL=

