{
  "name": "garcia-builder-stripe-integration",
  "version": "2.0.0",
  "description": "Premium Stripe payment integration for Garcia Builder coaching website",
  "main": "api/stripe-server-premium.js",
  "scripts": {
    "start": "node api/stripe-server-premium.js",
    "dev": "nodemon api/stripe-server-premium.js",
    "legacy": "node api/stripe-server.js",
    "test": "node scripts/contact-form.check.js && node scripts/lead-form-contract.check.js && node scripts/starter-assessment.check.js && node scripts/i18n-parity.check.js && node scripts/i18n-user-messages.check.js && node scripts/pricing-mypthub-packages.check.js && node scripts/ebook-popup.check.js && node scripts/auth-contract.check.js && node scripts/navbar-contract.check.js && node scripts/auth-login-register.check.js && node scripts/user-area-persistence.check.js",
    "test:auth": "node scripts/auth-login-register.check.js",
    "test:starter-assessment:smoke": "node scripts/starter-assessment-smoke.mjs",
    "test:nutrition-endpoint": "node scripts/nutrition-calculator-endpoint.check.js",
    "test:package-ctas": "node scripts/package-cta-contract.check.js",
    "test:e2e:user-area:live": "node scripts/live-user-area.e2e.mjs",
    "serve": "node tools/static-server.js",
    "sitemap": "node tools/generate-sitemap.js",
    "seo:apply": "node scripts/apply-technical-seo.js",
    "seo:sitemap": "node scripts/generate-sitemap.js",
    "seo:audit": "node scripts/seo-audit.js",
    "frontend:audit": "node scripts/frontend-audit.js",
    "build:seo": "node scripts/generate-sitemap.js && node scripts/seo-audit.js",
    "lint": "powershell -ExecutionPolicy Bypass -File validate-components.ps1",
    "build": "npm run build:env && npm run build:public",
    "seo:audit": "node scripts/seo-audit.js",
    "build:env": "node scripts/generate-env-config.js",
    "build:public": "node scripts/build-public-output.js",
    "filter:backup": "node scripts/filter-supabase-backup.js",
    "postinstall": "node scripts/generate-env-config.js --optional",
    "ship": "pwsh -NoLogo -ExecutionPolicy Bypass -File scripts/Invoke-Ship.ps1 -Project iron-brothers",
    "ship:ib": "pwsh -NoLogo -ExecutionPolicy Bypass -File scripts/Invoke-Ship.ps1 -Project iron-brothers",
    "ship:gb": "pwsh -NoLogo -ExecutionPolicy Bypass -File scripts/Invoke-Ship.ps1 -Project garcia-builder",
    "ci:prep": "npm run lint && npm run test --silent",
    "ci:build": "npm run build --silent",
    "ci:full": "npm run ci:prep && npm run ci:build",
    "git:safe-push": "node scripts/git-safe-push.mjs",
    "work": "cross-env PROJECT=iron-brothers node scripts/workflow.mjs",
    "work:ib": "cross-env PROJECT=iron-brothers node scripts/workflow.mjs",
    "work:gb": "cross-env PROJECT=garcia-builder node scripts/workflow.mjs"
  },
  "keywords": [
    "stripe",
    "payments",
    "coaching",
    "fitness"
  ],
  "author": "Garcia Builder",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^8.1.0",
    "garcia-builder-stripe-integration": "file:",
    "helmet": "^8.2.0",
    "nodemailer": "^9.0.1",
    "stripe": "^14.25.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "cross-env": "^7.0.3",
    "jsdom": "^26.1.0",
    "nodemon": "^3.1.14"
  },
  "engines": {
    "node": "22.x",
    "npm": ">=10.0.0"
  }
}
