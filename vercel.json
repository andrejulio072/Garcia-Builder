{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "garciabuilder.fitness"
        }
      ],
      "destination": "https://www.garciabuilder.fitness/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.garciabuilder.fitness"
        },
        {
          "type": "header",
          "key": "x-forwarded-proto",
          "value": "http"
        }
      ],
      "destination": "https://www.garciabuilder.fitness/:path*",
      "permanent": true
    },
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/programs.html",
      "destination": "/packages.html",
      "permanent": true
    },
    {
      "source": "/programs",
      "destination": "/packages.html",
      "permanent": true
    },
    {
      "source": "/lead-magnet.html",
      "destination": "/28-day-fat-loss-kickstart.html",
      "permanent": true
    },
    {
      "source": "/pages/public/lead-magnet.html",
      "destination": "/28-day-fat-loss-kickstart.html",
      "permanent": true
    },
    {
      "source": "/pages/public/lead-magnet",
      "destination": "/28-day-fat-loss-kickstart.html",
      "permanent": true
    },
    {
      "source": "/pages/public/login.html",
      "destination": "/pages/auth/login.html",
      "permanent": true
    },
    {
      "source": "/",
      "has": [
        {
          "type": "query",
          "key": "s"
        }
      ],
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/thank-you-application",
      "destination": "/thank-you-application.html"
    },
    {
      "source": "/thank-you-ebook",
      "destination": "/thank-you-ebook.html"
    },
    {
      "source": "/thanks-ebook.html",
      "destination": "/pages/public/thanks-ebook.html"
    },
    {
      "source": "/first-workout.html",
      "destination": "/pages/public/first-workout.html"
    },
    {
      "source": "/28-day-fat-loss-kickstart.pdf",
      "destination": "/assets/28-days-fat-loss-quickstart.pdf"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/stripe-server-premium.js"
    }
  ],
  "headers": [
    {
      "source": "/28-day-fat-loss-kickstart.pdf",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/pdf"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"28-Day-Fat-Loss-Kickstart-Garcia-Builder.pdf\""
        }
      ]
    },
    {
      "source": "/assets/28-days-fat-loss-quickstart.pdf",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/pdf"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"28-Days-Fat-Loss-Quickstart-Garcia-Builder.pdf\""
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, OPTIONS"
        }
      ]
    },
    {
      "source": "/js/:path*",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript; charset=utf-8"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/components/:path*",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/css/:path*",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/css; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/pages/auth/:path*",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive, nosnippet, noimageindex"
        }
      ]
    },
    {
      "source": "/pages/public/login.html",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive, nosnippet, noimageindex"
        }
      ]
    },
    {
      "source": "/my-profile.html",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive, nosnippet, noimageindex"
        }
      ]
    },
    {
      "source": "/success.html",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, follow, noarchive"
        }
      ]
    }
  ],
  "trailingSlash": false,
  "cleanUrls": false
}
