{
  "rewrites": [
    {
      "source": "/online-coaching",
      "destination": "/online-coaching.html"
    },
    {
      "source": "/packages",
      "destination": "/packages.html"
    },
    {
      "source": "/28-day-fat-loss-kickstart",
      "destination": "/28-day-fat-loss-kickstart.html"
    },
    {
      "source": "/apply",
      "destination": "/apply.html"
    },
    {
      "source": "/consultation",
      "destination": "/consultation.html"
    },
    {
      "source": "/thank-you-application",
      "destination": "/thank-you-application.html"
    },
    {
      "source": "/thank-you-ebook",
      "destination": "/thank-you-ebook.html"
    },
    {
      "source": "/start-fat-loss",
      "destination": "/start-fat-loss.html"
    },
    {
      "source": "/online-coaching-dublin",
      "destination": "/online-coaching-dublin.html"
    },
    {
      "source": "/12-week-transformation",
      "destination": "/12-week-transformation.html"
    },
    {
      "source": "/free-fat-loss-guide",
      "destination": "/free-fat-loss-guide.html"
    },
    {
      "source": "/blog",
      "destination": "/blog.html"
    },
    {
      "source": "/blog/:slug",
      "destination": "/blog/:slug.html"
    },
    {
      "source": "/privacy-policy",
      "destination": "/privacy.html"
    },
    {
      "source": "/terms",
      "destination": "/terms.html"
    },
    {
      "source": "/lead-magnet.html",
      "destination": "/pages/public/lead-magnet.html"
    },
    {
      "source": "/thanks-ebook.html",
      "destination": "/pages/public/thanks-ebook.html"
    },
    {
      "source": "/first-workout.html",
      "destination": "/pages/public/first-workout.html"
    },
    {
      "source": "/28-day-fat-loss-kickstart.pdf",
      "destination": "/assets/28-days-fat-loss-quickstart.pdf"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/stripe-server-premium.js"
    }
  ],
  "headers": [
    {
      "source": "/28-day-fat-loss-kickstart.pdf",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/pdf"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"28-Day-Fat-Loss-Kickstart-Garcia-Builder.pdf\""
        }
      ]
    },
    {
      "source": "/assets/28-days-fat-loss-quickstart.pdf",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/pdf"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"28-Days-Fat-Loss-Quickstart-Garcia-Builder.pdf\""
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, OPTIONS"
        }
      ]
    },
    {
      "source": "/js/:path*",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript; charset=utf-8"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/components/:path*",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/css/:path*",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/css; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "trailingSlash": false,
  "cleanUrls": false
}
